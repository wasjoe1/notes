    {
      "id": "o9cEJLhY-0yrZWmeDmWtq",
      "type": "text",
      "x": 2617.9512630006175,
      "y": 1282.6696150652758,
      "width": 557.2796630859375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
