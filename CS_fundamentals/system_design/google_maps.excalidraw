    {
      "id": "fCxkjSf_m4wWm58hZpweg",
      "type": "text",
      "x": 2313.18973658678,
      "y": 4919.232038944021,
      "width": 952.4193115234375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5F",
      "roundness": null,
      "seed": 558526048,
      "version": 656,
      "versionNonce": 312159840,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771581913501,
      "link": null,
      "locked": false,
      "text": "1st thought that comes to mind: why do we need this USER LOC DB?\n    we can just send to kafka right?\n1. you need queryable state\n    - what if we want to find all friends/ drivers nearby to u?\n    - what if u want to find current user?\n    - the kafka queue should not be your source of truth, it only has a limited retention period\n2. routing of load balancer\n    => acutally we might want a kafka consumer instead that uploads to kafka stream processors\n    => to not affect performance of the current app",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1st thought that comes to mind: why do we need this USER LOC DB?\n    we can just send to kafka right?\n1. you need queryable state\n    - what if we want to find all friends/ drivers nearby to u?\n    - what if u want to find current user?\n    - the kafka queue should not be your source of truth, it only has a limited retention period\n2. routing of load balancer\n    => acutally we might want a kafka consumer instead that uploads to kafka stream processors\n    => to not affect performance of the current app",
      "autoResize": true,
      "lineHeight": 1.25
    },
