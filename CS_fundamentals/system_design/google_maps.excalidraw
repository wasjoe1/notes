    },
    {
      "id": "kMYtc-z-c9mVS_mTYE_AK",
      "type": "text",
      "x": 282.8340958331585,
      "y": 3562.5002069091115,
      "width": 145.4799041748047,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4G",
