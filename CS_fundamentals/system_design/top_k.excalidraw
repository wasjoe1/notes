    {
      "id": "oox5vRdNHvUOdZ7mmB94d",
      "type": "text",
      "x": -835.0275187192483,
      "y": 2689.7395050886257,
      "width": 582.839599609375,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aY",
      "roundness": null,
      "seed": 2085251680,
      "version": 933,
      "versionNonce": 1374274464,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771499770382,
      "link": null,
      "locked": false,
      "text": "Cron making expesive DB queries (the aggregation queries)\n- aggregating \n- spark or hadoop\n    => scale out computation (parallizable computation)\n    => each machine,\n        for every video, compute all the views across the hrs\n    => each machine sort the subset of the day\n*doesnt make it more efficient => we are still throwing\nlarge amt of resources (hardware + CPU) to aggregate this\n\n\nhour, day, month?\nlets store them!\n3x the number of writes to the DB\nBUT we can read it immediately out of the DB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cron making expesive DB queries (the aggregation queries)\n- aggregating \n- spark or hadoop\n    => scale out computation (parallizable computation)\n    => each machine,\n        for every video, compute all the views across the hrs\n    => each machine sort the subset of the day\n*doesnt make it more efficient => we are still throwing\nlarge amt of resources (hardware + CPU) to aggregate this\n\n\nhour, day, month?\nlets store them!\n3x the number of writes to the DB\nBUT we can read it immediately out of the DB",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xbSzTtk1TF9ezLneLkKI-",
      "type": "text",
      "x": -4027.473778577457,
      "y": 2454.281614236308,
      "width": 182.28237915039062,
      "height": 24.819802640892703,
      "angle": 0,
      "strokeColor": "#e03131",
