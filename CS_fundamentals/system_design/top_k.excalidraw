    {
      "id": "_Bt30FQLOna06uJ4etEFa",
      "type": "text",
      "x": -2600.3416237299475,
      "y": 488.3318695441334,
      "width": 839.3195190429688,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 1141848672,
      "version": 418,
      "versionNonce": 902883936,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771484251235,
      "link": null,
      "locked": false,
      "text": "API; use RESTful API => this is functionally the contract that i need to implement\n\n- GET /views/top-k?window={window}&k={k} -> { videoId, views }[]\n\n*worrying about pagination:\n*note that we have already limited k to be of 1000, this will be at most a couple KBs\n*not a big payload => hence not need to build pagination infrastructure",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API; use RESTful API => this is functionally the contract that i need to implement\n\n- GET /views/top-k?window={window}&k={k} -> { videoId, views }[]\n\n*worrying about pagination:\n*note that we have already limited k to be of 1000, this will be at most a couple KBs\n*not a big payload => hence not need to build pagination infrastructure",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
