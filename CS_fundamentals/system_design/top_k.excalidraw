      "boundElements": [],
      "updated": 1771499826663,
      "link": null,
      "locked": false,
      "text": "assume that there is a video views topic\nsitting in kafka \nput tgt by some other service on utube\n\n*not asked to design utube with top-k feature\n*only asked to design top-k feature\n=> instead of making an API that would accept the view\n=> assume that someone is helping to track the views in a kafka topic\n=> going to have some kafka topics that record important events => event driven architecture",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "assume that there is a video views topic\nsitting in kafka \nput tgt by some other service on utube\n\n*not asked to design utube with top-k feature\n*only asked to design top-k feature\n=> instead of making an API that would accept the view\n=> assume that someone is helping to track the views in a kafka topic\n=> going to have some kafka topics that record important events => event driven architecture",
      "autoResize": true,
      "lineHeight": 1.25
    },
