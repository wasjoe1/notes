      "updated": 1771483590562,
      "link": null,
      "locked": false,
      "text": "(rational)\n1 min between when the event happens & when it\nis tabulated in our top-k\n*when it happens means when the vid hits alot\nof views im guessing\n* tabulated means when it is actually scored as\nthe top-k videos to be returned to our users\n=> helps us to set an upper bound limit to cache\nTTLs => too stale to be serving this (TTL\ncant be more than 1 min)\n=> out of order ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "(rational)\n1 min between when the event happens & when it is tabulated in our top-k\n*when it happens means when the vid hits alot of views im guessing\n* tabulated means when it is actually scored as the top-k videos to be returned to our users\n=> helps us to set an upper bound limit to cache TTLs => too stale to be serving this (TTL cant be more than 1 min)\n=> out of order ",
      "autoResize": false,
      "lineHeight": 1.25
    },
