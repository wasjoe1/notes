      "seed": 955799456,
      "version": 201,
      "versionNonce": 2120016480,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771744769216,
      "link": null,
      "locked": false,
      "text": "Req (fn & non fn)\ncore entities\nAPI / interface\nhigh lvl design => fn requirements\ndeep dives => non-fn reqs",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Req (fn & non fn)\ncore entities\nAPI / interface\nhigh lvl design => fn requirements\ndeep dives => non-fn reqs",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zPCW1PxNBm_SRX1u2lDFW",
      "type": "text",
      "x": 392.953809686455,
      "y": 228.72284380276443,
      "width": 663.259521484375,
      "height": 775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBS",
      "roundness": null,
      "seed": 1862369184,
      "version": 880,
      "versionNonce": 1289055840,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771745678375,
      "link": null,
      "locked": false,
      "text": "factory\ncontruction workers\nnext available worker => finishes the earliest job, gets the next job\n=> prioritizing the scheduling\n\n# workers?   [read=> QPS]\n# jobs?       [write => QPS] 10k/s\n# 24/7 factory [tap from multiple places => ACID DB]\n# no instructions [MEM]\n\n\nFUNC:\n- create jobs at timestamps\n- get latest job at timestamp\n- execute job at timestamp\n- update finish job Status\n\n---OOS----\n1 person can only work on 1 job at a time\n\nNON FUNC:\n- dont want same job to be executed by 2 person\n- writes => jobs are coming from client base (huge)\n- reads\n- templated job => no instruction, just need to know when to do it\n\ncore entities:\n- worker\n- scheduler\n- job\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "factory\ncontruction workers\nnext available worker => finishes the earliest job, gets the next job\n=> prioritizing the scheduling\n\n# workers?   [read=> QPS]\n# jobs?       [write => QPS] 10k/s\n# 24/7 factory [tap from multiple places => ACID DB]\n# no instructions [MEM]\n\n\nFUNC:\n- create jobs at timestamps\n- get latest job at timestamp\n- execute job at timestamp\n- update finish job Status\n\n---OOS----\n1 person can only work on 1 job at a time\n\nNON FUNC:\n- dont want same job to be executed by 2 person\n- writes => jobs are coming from client base (huge)\n- reads\n- templated job => no instruction, just need to know when to do it\n\ncore entities:\n- worker\n- scheduler\n- job\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "unAn51TKuQGMf0cCBkmZL",
      "type": "text",
      "x": 385.5124582828612,
      "y": 1020.4524634425235,
      "width": 456.23974609375,
      "height": 550,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBT",
      "roundness": null,
      "seed": 422932384,
      "version": 1193,
      "versionNonce": 74468256,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771757609353,
      "link": null,
      "locked": false,
      "text": "API\n# Client service\ncreateJob()\nPOST /api/jobs/createJob/\nreq: timestamp, creatorId, timeToFinish => Job\nres: - 200 OK\n\n# Worker service\nviewAllJobs()\nGET /api/jobs/allJobs\n\nviewJob(jobId)\nGET /api/jobs/{jobId}\n\nupdateJob\nPATCH /api/jobs/{jobId}\nreq: {status: done | in progress | todo }\n\n\n# Scheduling service (on the BE)\ngetJobsTodo()\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n# Client service\ncreateJob()\nPOST /api/jobs/createJob/\nreq: timestamp, creatorId, timeToFinish => Job\nres: - 200 OK\n\n# Worker service\nviewAllJobs()\nGET /api/jobs/allJobs\n\nviewJob(jobId)\nGET /api/jobs/{jobId}\n\nupdateJob\nPATCH /api/jobs/{jobId}\nreq: {status: done | in progress | todo }\n\n\n# Scheduling service (on the BE)\ngetJobsTodo()\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
