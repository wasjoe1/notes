    {
      "id": "rGWdZSpfQDLrGGt0Ty7yG",
      "type": "text",
      "x": 40.1690213090792,
      "y": 221.20977614289882,
      "width": 321.039794921875,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
