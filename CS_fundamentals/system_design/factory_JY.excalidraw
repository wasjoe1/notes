    {
      "id": "bH68p-B5ebe8QcZYBmsdt",
      "type": "text",
      "x": 2712.7785320033768,
      "y": 443.90472041014186,
      "width": 769.219482421875,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBs",
      "roundness": null,
      "seed": 786527136,
      "version": 486,
      "versionNonce": 1968448096,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771757493444,
      "link": null,
      "locked": false,
      "text": "Jobs\n    timestamp => indexed : 8 bytes (sortkey)\n    jobId : 8 byets\n    timeToFinish: 8 bytes\n    \n    workerId: NIL\n    status: todo | inprogress | Done (partition key)\n\nWorkers\n    workerId\n    nextAvailableTime\n    ...metadata\n    * worker complestes their prev work on time\n    * worker will immediately start on task once ready\n    * workers will start working on jobs (3 jobs assigned to 3 different people)\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Jobs\n    timestamp => indexed : 8 bytes (sortkey)\n    jobId : 8 byets\n    timeToFinish: 8 bytes\n    \n    workerId: NIL\n    status: todo | inprogress | Done (partition key)\n\nWorkers\n    workerId\n    nextAvailableTime\n    ...metadata\n    * worker complestes their prev work on time\n    * worker will immediately start on task once ready\n    * workers will start working on jobs (3 jobs assigned to 3 different people)\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
