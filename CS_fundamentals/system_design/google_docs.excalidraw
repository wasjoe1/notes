    {
      "id": "KlOD_yb3JXVoYcxxBGlB6",
      "type": "text",
      "x": 974.8264463562136,
      "y": 641.0697261188639,
      "width": 806.179443359375,
      "height": 475,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bAV",
      "roundness": null,
      "seed": 1346346912,
      "version": 1260,
      "versionNonce": 304896608,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771740692401,
      "link": null,
      "locked": false,
      "text": "deep dives1: ensure that clients are able to send edits to 1 another (connectivity)\ndeep dives2: edits are sent & received in real time\ndeep dive3: sending & getting pos of user on doc\n\nDD1\n100mil DAU == > 1000 connections / s\nmultiple servers\n\nsoln1: kafka\n100kB * 100 mil DAU = 100 billion bytes = 10TB\n\nsoln2: redis pub sub\n10KB * 100 mil DAU = 50 billion bytes = 10GB\n\n1 billion users\n10 billion user\n\nsoln3: consistent hashing\nfor stateful servers",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "deep dives1: ensure that clients are able to send edits to 1 another (connectivity)\ndeep dives2: edits are sent & received in real time\ndeep dive3: sending & getting pos of user on doc\n\nDD1\n100mil DAU == > 1000 connections / s\nmultiple servers\n\nsoln1: kafka\n100kB * 100 mil DAU = 100 billion bytes = 10TB\n\nsoln2: redis pub sub\n10KB * 100 mil DAU = 50 billion bytes = 10GB\n\n1 billion users\n10 billion user\n\nsoln3: consistent hashing\nfor stateful servers",
      "autoResize": true,
      "lineHeight": 1.25
    },
