      "text": "API\nWebsocket - bidrectional\n\nWS ws/connect\nsendEdits\nrecvEdits\n\nAPI\nPOST /api/createDoc\n\n{\n    title: documentName\n}\n\nGET /api/getDoc\nreq: docId, docName\n\nGET /api/getUserPos\nreq: userId",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\nWebsocket - bidrectional\n\nWS ws/connect\nsendEdits\nrecvEdits\n\nAPI\nPOST /api/createDoc\n\n{\n    title: documentName\n}\n\nGET /api/getDoc\nreq: docId, docName\n\nGET /api/getUserPos\nreq: userId",
      "autoResize": true,
      "lineHeight": 1.25
    },
