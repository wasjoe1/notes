      "isDeleted": false,
      "boundElements": null,
      "updated": 1771515014269,
      "link": null,
      "locked": false,
      "text": "Core entities:\n- ride\n- driver\n- rider\n- location ?? => most up to location of my driver",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n- ride\n- driver\n- rider\n- location ?? => most up to location of my driver",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oL3fecn0Ln-6ds9Fk4RAA",
      "type": "text",
      "x": -1083.8586699294676,
      "y": 1526.4538416402345,
      "width": 849.0995483398438,
      "height": 925,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0g",
      "roundness": null,
      "seed": 801881696,
      "version": 948,
      "versionNonce": 1288549984,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771515014269,
      "link": null,
      "locked": false,
      "text": "API\n\n- # get an estimate\nPOST /ride/fare-estimate -> Partial<Ride>\n{\n    src,\n    dest\n}\n\n- # rider need to req a ride\n    # happens asynchronously\nPOST /ride/request?rideId{rideId} -> 200/ 400 (for failure)\n{\n    rideId\n    XX => shouold not put userId => should be in the JWT in the header; not the body\n}\n\n- # get rider's location => ping\nPOST /location/update\n{\n    lat,\n    long\n}\n\n- # for driver to accept\nPATCH /ride/driver/accept\n{\n    rideId\n    true/false => accept or deny matching\n}\n\n- # udpate our system when they got to the src\nPATCH /ride/driver/update -> lat/ long | null\n{\n    rideId\n    status: 'pickedup' | 'droppedoff'\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\n- # get an estimate\nPOST /ride/fare-estimate -> Partial<Ride>\n{\n    src,\n    dest\n}\n\n- # rider need to req a ride\n    # happens asynchronously\nPOST /ride/request?rideId{rideId} -> 200/ 400 (for failure)\n{\n    rideId\n    XX => shouold not put userId => should be in the JWT in the header; not the body\n}\n\n- # get rider's location => ping\nPOST /location/update\n{\n    lat,\n    long\n}\n\n- # for driver to accept\nPATCH /ride/driver/accept\n{\n    rideId\n    true/false => accept or deny matching\n}\n\n- # udpate our system when they got to the src\nPATCH /ride/driver/update -> lat/ long | null\n{\n    rideId\n    status: 'pickedup' | 'droppedoff'\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
