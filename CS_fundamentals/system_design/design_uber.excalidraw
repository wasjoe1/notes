    },
    {
      "id": "u62GHvO5qbINrsfDNdzOO",
      "type": "text",
      "x": 932.9259525818782,
      "y": 1816.741574406011,
      "width": 341.73980712890625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1l",
      "roundness": null,
      "seed": 211982944,
      "version": 219,
      "versionNonce": 2036040288,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771515014270,
      "link": null,
      "locked": false,
      "text": "given that during peak periods\nwe start to have alot of requests\n=> can use a request queue to help\nprevent overloading of our\nmatching server instances",
      "fontSize": 20,
      "fontFamily": 5,
