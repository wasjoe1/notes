    {
      "id": "DufMbebAtvzOC_yydFE56",
      "type": "text",
      "x": 1406.0673766208577,
      "y": 2537.208386290158,
      "width": 263.53985595703125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
