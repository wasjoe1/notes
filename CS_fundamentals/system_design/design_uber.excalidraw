    {
      "id": "nua9sbV-jANucCI0jS2s3",
      "type": "text",
      "x": 2274.992365567914,
      "y": 2923.446636602442,
      "width": 895.5593872070312,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1d",
      "roundness": null,
      "seed": 1730752096,
      "version": 206,
      "versionNonce": 1306207136,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771515014270,
      "link": null,
      "locked": false,
      "text": "- since we have 2 redis instances we could consider just combining both tgt\n- DynamoDB for primary DB => not alot of complex queries or relations, and can auto scale\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- since we have 2 redis instances we could consider just combining both tgt\n- DynamoDB for primary DB => not alot of complex queries or relations, and can auto scale\n",
      "autoResize": true,
