    {
      "id": "QmJiA6zEu1I5Jc4FjtRrh",
      "type": "text",
      "x": 2291.8214318676087,
      "y": 3139.5807104086307,
      "width": 657.7593994140625,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1u",
      "roundness": null,
      "seed": 836163488,
      "version": 575,
      "versionNonce": 500650592,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1771515014270,
      "link": null,
      "locked": false,
      "text": "- ride request queue\n- FIFO queue\n- matching service will pull out of this queue\n- queue will be parititioned by regions\n- request comes in first => in the boonies, and \n- other ppl stuck in this queue in highly dense areas\n- partition this queue based on regions/ locations \n- within NYC, might want to have finer grained partition\n- if any matching service goes down, we will pull off the queue again\n\nscaling in general via horizontal scale\nparition based on region\nlocated in different centres (co-located) \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- ride request queue\n- FIFO queue\n- matching service will pull out of this queue\n- queue will be parititioned by regions\n- request comes in first => in the boonies, and \n- other ppl stuck in this queue in highly dense areas\n- partition this queue based on regions/ locations \n- within NYC, might want to have finer grained partition\n- if any matching service goes down, we will pull off the queue again\n\nscaling in general via horizontal scale\nparition based on region\nlocated in different centres (co-located) \n",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
