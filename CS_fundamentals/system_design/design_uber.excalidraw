    {
      "id": "kv4qmnaM8VqkDgENFJ4se",
      "type": "text",
      "x": 975.7007505544399,
      "y": 2894.719429182725,
      "width": 365.7197265625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
