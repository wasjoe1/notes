      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities\n- Users (sender/ receiver) => no privieleged actors, all users are peers\n    - online status\n- Messages\n- group chat",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LM7klIAfyoJz059clgDrj",
      "type": "text",
      "x": 420.2510184249825,
      "y": 1263.6249086205921,
      "width": 817.3794555664062,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
