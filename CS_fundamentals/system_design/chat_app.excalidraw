    {
      "id": "r1Q2ChEv1mZiu9YAUS6yZ",
      "type": "text",
      "x": 1330.5502351149894,
      "y": 137.19945213416167,
      "width": 162.3198699951172,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
