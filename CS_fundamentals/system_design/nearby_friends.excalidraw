    {
      "id": "0T8H5rTxG0k6btgeKTxM7",
      "type": "text",
      "x": 130.51821864371328,
      "y": 4207.305624745961,
      "width": 532.8396606445312,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
