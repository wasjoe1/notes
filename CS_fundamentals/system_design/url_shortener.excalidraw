    {
      "id": "3i_1wP-fCTAiLLE0blJXZ",
      "type": "text",
      "x": 3.09375,
      "y": 78.48828125,
      "width": 261.27978515625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
