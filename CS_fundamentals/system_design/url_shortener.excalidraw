      "isDeleted": false,
      "boundElements": null,
      "updated": 1771590374733,
      "link": null,
      "locked": false,
      "text": "reqs (fn, non-fn)\ncore entities (items in DB)\nAPI\nhigh level design -> fn\ndeep dives -> non fn",
